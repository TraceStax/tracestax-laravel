{
    "name": "tracestax/laravel-tracestax",
    "version": "0.1.0",
    "description": "TraceStax monitoring for Laravel Queue — worker intelligence and observability for your background jobs",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "queue",
        "monitoring",
        "observability",
        "worker",
        "jobs"
    ],
    "authors": [
        {
            "name": "TraceStax",
            "email": "eng@tracestax.com"
        }
    ],
    "homepage": "https://tracestax.com",
    "require": {
        "php": ">=8.1",
        "illuminate/support": ">=10.0",
        "guzzlehttp/guzzle": ">=7.0"
    },
    "autoload": {
        "psr-4": {
            "TraceStax\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TraceStax\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TraceStax\\Laravel\\TraceStaxServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
